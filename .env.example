# LoanScore backend configuration
# Copy this file to .env and adjust values as needed.
# All values shown are the defaults used by app/core/config.py

# Display name shown in API docs and dashboard
PROJECT_NAME=LoanScore

# API version string returned in OpenAPI schema
API_VERSION=0.1.0

# development | staging | production
ENVIRONMENT=development

# Comma-separated list is not supported directly by pydantic-settings list parsing
# via env vars without a custom parser; override CORS in code if you need to change
# allowed origins for a deployed environment. Defaults already allow:
#   http://localhost:5173, http://127.0.0.1:5173
#   http://localhost:3000, http://127.0.0.1:3000

# Frontend (.env in frontend/ directory)
# VITE_API_BASE_URL=http://127.0.0.1:8000
